{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ESNext"],
		// Dynamic imports, import.meta, top-level await and import attributes are all unsupported.
		"module": "ES2015",
		"baseUrl": "scripts/",
		"rootDir": "scripts/",
		"outDir": "script_dist/",
		"alwaysStrict": true,
		"isolatedModules": false,
		"allowJs": true,
		"strict": false,
		"noImplicitAny": false,
		"experimentalDecorators": true,
		"paths": {
			"@util": ["util/index.mts"]
		},
		"typeRoots": ["./scripts/types-mom"] // If you error here, you don't have the submodule installed! (git submodule update --init --recursive)
	},
	"include": ["scripts/"],
	"exclude": ["*.d.ts"]
}
