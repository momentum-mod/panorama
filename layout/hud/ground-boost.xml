<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>
	
	<scripts>
		<include type="module" src="file://{scripts}/hud/ground-boost.ts" />
	</scripts>

	<MomHudGroundboost alternateTicks="false">
		<Panel id="GroundboostContainer" class="groundboost__container groundboost__container--hide">
            <!-- This is remade in js whenever the size changes to re-rasterize svgs -->
			<Image id="GroundboostBackground" class="groundboost__background-meter" src="file://{images}/hud/meter-ring.svg" textureheight="100" />
            <Image id="GroundboostMeter" class="groundboost__meter" src="file://{images}/hud/meter-ring.svg" textureheight="100" />
			<Label id="GroundboostLabel" text="" class="groundboost__label" />
		</Panel>
	</MomHudGroundboost>
</root>
