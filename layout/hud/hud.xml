<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>

	<Hud class="hud" hittest="false" useglobalcontext="false">
		<!-- Non-interactive HUD elements have hit test disabled for efficiency -->

		<!-- In world UI is first to make sure it shows up behind all "screen-looking" UI -->
		<Panel class="hud__in-world" hittest="false" hittestchildren="false">
			<MomHudGhostEntities />
			<MomHudConcEntities /> <!-- TODO: Not in customizer -->
			<MomHudDamageIndicator />
			<MomHudCgaz /> <!-- TODO: Not in customizer -->
			<MomHudReticle />
		</Panel>

		<!-- Customizer grid needs to live outside HudCustomizer layout so it's below everything else in z-order -->
		<Panel id="HudCustomizerGrid" class="hud-customizer-grid" hittest="false" hittestchildren="false" />

        <MomHudMapInfo id="MapInfo" />
        <MomHudStatus id="Status" />
		<MomHudTimer id="Timer" />
        <MomHudChat id="Chat" />
		<HudComparisons id="Comparisons" />

        <MomHudStrafeTrainer id="StrafeTrainer"/> 
        <MomHudJumpStats id="JumpStats"/>
        <MomHudStickyCharge id="StickyCharge" />
		<MomHudStickyCount id="StickyCount" />
        <MomHudConcCooktime id="ConcCooktime" />

		<ConVarEnabler convar="mom_zoning_enable" togglevisibility="true">
			<MomHudZoning /> <!-- TODO: HudBottomCenter, not in customizer -->
		</ConVarEnabler>

        <MomHudSafeguardIndicator /> <!-- TODO: HudCenter, not in customizer -->
		<MomHudJumpTiming /> <!-- TODO: HudCenter, not added to customizer -->
		<MomHudSpeedometer id="Speedometer" /> <!-- TODO: HudBottomCenter, not in customizer -->
		<MomHudGroundboost id="MomHudGroundboost" /> <!-- TODO: HudBottomCenter, not in customizer -->
		<HudHintText id="HudHintText" /> <!-- TODO: not in customizer -->
		<MomHudPowerupTimer /> <!-- TODO: LowerLeft, not added to customizer -->
		<HudStaticMenu id="StaticMenu" /> <!-- TODO: not in customizer -->
		<MomHudDFJump /> <!-- TODO: BottomRight, not added to customizer -->
		<MomHudAmmo /> <!-- TODO: BottomRight, not added to customizer -->
		<MomHudKeyPress id="KeyPress" /> <!-- TODO: Not really in customizer, needs a rework -->
		<MomHudSpecInfo id="SpecInfo" /> <!-- TODO: not in customizer -->
		<MomHudWeaponSelection id="WeaponSelection" /> <!-- TODO: not in customizer -->
		<HudShowPos id="ShowPos" /> <!-- TODO: not in customizer -->
		<HudBoneCounts id="BoneCount" /> <!-- TODO: HudTopCenter, not in customizer -->
		<MomHudSpectate id="Spectator" /> <!-- TODO: HudTopCenter, not in customizer -->
		

        <!-- <MomHudStrafeSync id="StrafeSync" /> This is broken and probably not worth fixing --> 

		<HudBlurTarget id="HudBlur" blurrects="TabMenu Spectator" class="hud-blur" hittest="false" hittestchildren="false">
			<BackbufferImagePanel class="full" />
		</HudBlurTarget>

		<HudBlurTarget id="HudWeakBlur" blurrects="" class="hud-blur hud-blur--weak" hittest="false" hittestchildren="false">
			<BackbufferImagePanel class="full" />
		</HudBlurTarget>

		<Panel id="ZoningContainer" hittestchildren="true">
			<ZoneMenu id="ZoneMenu" hittest="true" hittestchildren="true" /> <!-- TODO: standalone panel, not in customizer -->
		</Panel>

		<!-- This container is here so we can move the leaderboard in and out of it during the end-of-match sequence -->
		<!-- TODO: HudLeaderboards had w-full h-full removed before -->
		<Panel id="TabMenuContainer" hittest="false" hittestchildren="true">
			<HudTabMenu id="TabMenu" hittest="true" />
		</Panel>
		
		<HudCustomizer />

		<!-- Make sure these are at the bottom to get the z-order right -->
		<ToastManager />
		<PopupManager id="PopupManager" onpopupsdismissed="" />
		<ContextMenuManager id="ContextMenuManager" />
		<TooltipManager id="TooltipManager" hittest="false" />

		<!-- Console notifications should always draw above anything else! -->
		<Panel id="HudNotify" hittest="false" hittestchildren="false">
			<Frame src="file://{resources}/layout/hud/console-notify.xml" />
		</Panel>
	</Hud>
</root>
