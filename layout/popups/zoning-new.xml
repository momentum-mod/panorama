<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>

	<scripts>
		<include src="file://{scripts}/pages/zoning/zoning.js" />
	</scripts>

	<PopupCustomLayout class="PopupPanel Hidden" popupbackground="dim" onload="">
		<Panel class="learn-header__modes-bar tabs">
            <RadioButton id="BonusRadio" class="tabs__tab learn-header__modes-tab" group="ZoningNew" onactivate="ZoneMenu.setNewObjectType('Bonus');">
                <Label class="tabs__text" text="#Zoning_AddBonus" />
            </RadioButton>
            <Panel class="tabs__gap" />
            <RadioButton id="SegmentRadio" class="tabs__tab learn-header__modes-tab" group="ZoningNew" onactivate="ZoneMenu.setNewObjectType('Segment');">
                <Label class="tabs__text" text="#Zoning_AddSegment" />
            </RadioButton>
            <Panel class="tabs__gap" />
            <RadioButton id="CheckpointRadio" class="tabs__tab learn-header__modes-tab" group="ZoningNew" onactivate="ZoneMenu.setNewObjectType('Checkpoint');">
                <Label class="tabs__text" text="#Zoning_AddCheckpoint" />
            </RadioButton>
            <Panel class="tabs__gap" />
            <RadioButton id="EndRadio" class="tabs__tab learn-header__modes-tab" group="ZoningNew" onactivate="ZoneMenu.setNewObjectType('End');">
                <Label class="tabs__text" text="#Zoning_AddEnd" />
            </RadioButton>
            <Panel class="tabs__gap" />
            <RadioButton id="CancelRadio" class="tabs__tab learn-header__modes-tab" group="ZoningNew" onactivate="ZoneMenu.setNewObjectType('Cancel');">
                <Label class="tabs__text" text="#Zoning_AddCancel" />
            </RadioButton>
        </Panel>
        <Button class="button button--blue" onactivate="ZoneMenu.addObjectToMapZones();UiToolkitAPI.CloseAllVisiblePopups()">
            <Label class="button__text" text="#Zoning_Create" />
        </Button>
	</PopupCustomLayout>
</root>